{
  "name": "iobroker.nextcloudtalk",
  "version": "1.0.2",
  "description": "ioBroker.NextcloudTalk",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "test": "jest",
    "test:js": "node ./node_modules/@iobroker/testing/node_modules/mocha/bin/mocha.js --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "node ./node_modules/@iobroker/testing/node_modules/mocha/bin/mocha.js test/package --exit",
    "test:integration": "node ./node_modules/@iobroker/testing/node_modules/mocha/bin/mocha.js test/integration --exit",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "keywords": [
    "ioBroker",
    "adapter",
    "nextcloud",
    "talk",
    "notifications"
  ],
  "author": "Rello",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rello/ioBroker.nextcloudtalk"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.16.5",
    "jest": "^30.3.0",
    "proxyquire": "^2.1.3",
    "typescript": "~5.0.4"
  },
  "files": [
    "admin",
    "main.js",
    "io-package.json",
    "LICENSE"
  ]
}
